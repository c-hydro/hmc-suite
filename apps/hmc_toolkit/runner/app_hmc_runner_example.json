        "template": {
          "domain_name": "string",
          "path_source": "string",
          "path_destination": "string",
          "time_now": "%Y%m%d%H00",
          "time_period": "string"
        }
      },
      "hmc" : {
        "complete_by_info": {
          "sDomainName": "{domain_name}",
          "sPathData_Static_Point": ".{path_source}/{domain_name}/",
