{
  "__comment__" : "configuration file for the hmc namelist",
  "info_namelist": {
    "type": "hmc",
    "version": "3.2.0",
    "flags": {
      "clean_data": true
    },
    "variables": {
      "environment": {
        "lut": {
          "domain_name": "DOMAIN_NAME",
          "path_source" : "PATH_SRC",
          "path_destination" : "PATH_DST",
          "time_now" : "TIME_NOW",
          "time_period" : "TIME_PERIOD",
          "path_namelist": "PATH_NAMELIST",
          "file_namelist": "FILE_NAMELIST"
        },
        "format": {
          "domain_name": "string",
          "path_source": "string",
          "path_destination": "string",
          "time_now": "timestamp",
          "time_period": "int",
          "path_namelist": "string",
          "file_namelist": "string"
        },
        "template": {
          "domain_name": "string",
          "path_source": "string",
          "path_destination": "string",
          "time_now": "%Y%m%d%H00",
          "time_period": "int",
          "path_namelist": "string",
          "file_namelist": "string"
        }
      },
      "hmc" : {
        "complete_by_info": {
          "sDomainName": "{domain_name}",
          "sPathData_Static_Point": ".{path_source}/{domain_name}/",
          "sPathData_State_Point": "./data/static/point/",
          "sPathData_Static_Gridded": "./data/static/point/",
          "sPathData_State_Gridded": "./data/static/point/{domain_name}/",
          "sPathData_Outcome_Point": "./data/static/point/{domain_name}/%YYYY/%DD/%MM/",
          "sTimeStart": "{time_now}",
          "sSimLength": "{time_period}",
          "iTVeg": 800
        },
        "complete_by_pattern": {
          "pattern_dt": {
            "active": true, "template": "iDt", "value": 3600},
          "pattern_path_data": {
            "active": true, "template": "sPathData", "value": "/"}
        }
      }
    },
    "data": {
      "source": {
        "folder_name": "",
        "file_name": "hmc.template.info.v3.1.6.txt"
      },
      "destination": {
        "folder_name": "{path_namelist}",
        "file_name": "{file_namelist}"
      }
    }
  },
  "time": {
    "time_now": null,
    "time_period": 12,
    "time_start": null,
    "time_end": null,
    "time_rounding": "H",
    "time_frequency": "H"
  },
  "log": {
    "folder_name": "log",
    "file_name": "hmc_namelist.log"
  },
  "tmp": {
    "folder_name": "tmp",
    "file_name": "hmc_namelist.tmp"
  }
}
